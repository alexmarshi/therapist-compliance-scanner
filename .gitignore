# Node.js standard ignores

# Logs
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.log

# Directory for instrumented libs generated by jscoverage/Jest
lib-cov/

# Coverage output
coverage/

# Dependency directories
node_modules/  
bower_components/  

# Build outputs
/dist/
/build/
/.next/

# Next.js specific ignores
/.next/
out/

# Miscellaneous
.DS_Store
*.tgz
*.lock-a
*.log
.idea/
.vscode/
